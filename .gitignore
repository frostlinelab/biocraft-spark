.idea
.vscode/
.venv
.trae
.DS_Store
*.sqlite3
__pycache__/
*.py[cod]

# Frontend/Tauri rules
frontend/node_modules/
frontend/dist/
frontend/src-tauri/target/

# Root-level (accidental installs)
node_modules/
package.json
package-lock.json

# LLM data and models
.claude

# Uploaded workflow files
# Ignore directory contents (not the dir itself) so .gitkeep stays trackable.
uploads/*
!uploads/.gitkeep

# User-installed plugins via Marketplace (local runtime state, not source)
plugins/*
!plugins/.gitkeep

# Generated outputs from workflow and FastQC integration tests
run_outputs/
tests/fastqc/outputs/*
!tests/fastqc/outputs/.gitkeep

# Local convenience scripts (personal launcher, not part of the project)
run.sh
